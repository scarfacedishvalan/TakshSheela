{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FaultScenario",
  "description": "Resolved, injectable fault specification. Derived from fault_candidates and IR. Drives fault injection and observability synthesis.",
  "type": "object",
  "required": ["scenario_id", "spec_id", "ir_id", "version", "fault", "observability", "artifact_lineage"],
  "properties": {
    "scenario_id": { "type": "string" },
    "spec_id": { "type": "string" },
    "ir_id": { "type": "string" },
    "version": { "type": "string" },
    "fault": {
      "type": "object",
      "required": ["fault_id", "mechanism_family", "mechanism_subtype", "target_module", "target_function", "injection_type", "injection_description", "estimated_difficulty"],
      "properties": {
        "fault_id": { "type": "string" },
        "mechanism_family": {
          "type": "string",
          "enum": ["semantic", "state", "temporal", "coordination", "resource", "contract"]
        },
        "mechanism_subtype": { "type": "string" },
        "target_module": { "type": "string", "description": "Dotted Python module path" },
        "target_function": { "type": "string" },
        "injection_type": {
          "type": "string",
          "enum": ["mutation", "omission", "delay", "reorder", "corrupt_state", "wrong_value"]
        },
        "injection_description": { "type": "string", "description": "Precise description of what is changed and why it causes the fault" },
        "estimated_difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
        "required_capabilities": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "observable_symptoms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["signal_type", "description"],
        "properties": {
          "signal_type": { "type": "string", "enum": ["log", "metric", "trace", "alert", "behavior"] },
          "description": { "type": "string" },
          "appears_after_seconds": { "type": "number" }
        },
        "additionalProperties": false
      }
    },
    "observability": {
      "type": "object",
      "required": ["level"],
      "properties": {
        "level": { "type": "string", "enum": ["none", "basic", "structured", "full"] },
        "artifacts": {
          "type": "array",
          "items": { "type": "string", "description": "Relative paths to synthesized observability files" }
        }
      },
      "additionalProperties": false
    },
    "artifact_lineage": {
      "type": "object",
      "required": ["ir_id", "ir_hash", "fault_candidate_ref", "generated_at"],
      "properties": {
        "ir_id": { "type": "string" },
        "ir_hash": { "type": "string" },
        "fault_candidate_ref": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
